{
    "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
    "version": 1,
    "cli": {
        "packageManager": "npm",
        "analytics": "feb83804-1512-47e2-b147-cce5b13bd449"
    },
    "newProjectRoot": "projects",
    "projects": {
        "UMP_GIS_APPLICATION": {
            "projectType": "application",
            "schematics": {},
            "root": "",
            "sourceRoot": "src",
            "prefix": "app",
            "architect": {
                "build": {
                    "builder": "@angular/build:application",
                    "options": {
                        "outputPath": {
                            "base": "dist/UMP_GIS_APPLICATION",
                            "browser": ""
                        },
                        "browser": "src/main.ts",
                        "tsConfig": "tsconfig.app.json",
                        "assets": [
                            "src/favicon.ico",
                            {
                                "glob": "**/*",
                                "input": "src/assets",
                                "output": "assets"
                            }
                        ],
                        "styles": [
                            "node_modules/@fortawesome/fontawesome-free/css/all.min.css",
                            "node_modules/bootstrap-icons/font/bootstrap-icons.css",
                            "node_modules/bootstrap/dist/css/bootstrap.min.css",
                            "node_modules/leaflet/dist/leaflet.css",
                            "src/styles.css"
                        ],
                        "scripts": [
                            "node_modules/bootstrap/dist/js/bootstrap.bundle.min.js"
                        ],
                        "allowedCommonJsDependencies": [
                            "leaflet",
                            "leaflet-polylinedecorator"
                        ]
                    },
                    "configurations": {
                        "production": {
                            "budgets": [
                                {
                                    "type": "initial",
                                    "maximumWarning": "1MB",
                                    "maximumError": "2MB"
                                },
                                {
                                    "type": "anyComponentStyle",
                                    "maximumWarning": "10kB",
                                    "maximumError": "20kB"
                                }
                            ],
                            "outputHashing": "all"
                        },
                        "staging": {
                            "optimization": true,
                            "sourceMap": true,
                            "extractLicenses": false,
                            "outputHashing": "all"
                        },
                        "development": {
                            "optimization": false,
                            "extractLicenses": false,
                            "sourceMap": true
                        }
                    },
                    "defaultConfiguration": "production"
                },
                "serve": {
                    "builder": "@angular/build:dev-server",
                    "configurations": {
                        "production": {
                            "buildTarget": "UMP_GIS_APPLICATION:build:production"
                        },
                        "development": {
                            "buildTarget": "UMP_GIS_APPLICATION:build:development"
                        }
                    },
                    "defaultConfiguration": "development",
                    "options": {
                        "proxyConfig": "proxy.conf.json"
                    }
                },
                "test": {
                    "builder": "@angular/build:unit-test"
                }
            }
        }
    }
}
